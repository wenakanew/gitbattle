# Copy to .env — see repo root /.env.example for full comments

# PostgreSQL — use environment variables for credentials
# POSTGRES_USER and POSTGRES_PASSWORD should come from .env or docker-compose
DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/gitbattle"
REDIS_URL="redis://localhost:6379"
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
JWT_SECRET=dev-only-change-me-use-openssl-rand-base64-32

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5173/auth/github/callback
