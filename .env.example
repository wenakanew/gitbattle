# Copy to apps/server/.env for local backend (never commit secrets)

# PostgreSQL — matches docker-compose defaults
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gitbattle"

REDIS_URL="redis://localhost:6379"

# Server
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173

# Auth — generate a random 32+ byte secret for production
JWT_SECRET=dev-only-change-me-use-openssl-rand-base64-32

# GitHub OAuth app (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Dev: use Vite on :5173 with proxy so the session cookie is first-party.
# Register this exact URL in your GitHub OAuth app (Authorization callback).
GITHUB_CALLBACK_URL=http://localhost:5173/auth/github/callback
